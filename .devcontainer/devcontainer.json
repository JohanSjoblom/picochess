{
  "name": "Picochess contributor workspace",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -r requirements.txt -r test-requirements.txt tox",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ],
      "settings": {
        "python.testing.unittestEnabled": true,
        "python.testing.pytestEnabled": false
      }
    }
  }
}
